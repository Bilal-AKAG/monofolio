---
import { portfolioConfig } from "@/config/portfolio";
import { HandHeart } from "@lucide/astro";

const { name, role, location, socials } = portfolioConfig;
---

<section class="flex w-full border-y border-dashed border-border">
  <div class="flex w-full flex-col">
    <div class="flex items-center gap-2 px-4 pt-3 pb-1">
      <p class="font-mono text-[11px] text-muted-foreground flex items-center gap-1.5">
        <span>Welcome</span>
        <HandHeart size={12} />
      </p>
      <span class="inline-block h-[5px] w-[5px] rounded-full bg-primary" />
    </div>

    <div class="flex w-full items-center justify-between border-y border-dashed border-border px-4 py-3">
      <div class="flex flex-col gap-1">
        <h1 class="font-medium text-xl tracking-tight">
          {name}
        </h1>
        <p class="text-xs text-muted-foreground">
          {role}
          {location && ` • ${location}`}
        </p>
      </div>

      <nav class="flex items-center gap-3 text-xs text-muted-foreground">
        {socials?.github && (
          <a href={socials.github} class="hover:text-foreground underline-offset-4 hover:underline" target="_blank" rel="noreferrer">
            GitHub
          </a>
        )}
        {socials?.x && (
          <a href={socials.x} class="hover:text-foreground underline-offset-4 hover:underline" target="_blank" rel="noreferrer">
            X
          </a>
        )}
        {socials?.linkedin && (
          <a href={socials.linkedin} class="hover:text-foreground underline-offset-4 hover:underline" target="_blank" rel="noreferrer">
            LinkedIn
          </a>
        )}
        {socials?.email && (
          <a href={socials.email} class="hover:text-foreground underline-offset-4 hover:underline">
            Email
          </a>
        )}
      </nav>
    </div>

    <div class="px-4 py-3 text-sm text-muted-foreground">
      {portfolioConfig.bio}
    </div>
  </div>
</section>

