---
import { portfolioConfig } from "@/config/portfolio";
import {MapPin} from "@lucide/astro"
const { name, role, location, socials, bio } = portfolioConfig;

function parseBio(text: string) {
  const parts = text.split(/(~[^~]+~)/g);
  return parts.map((part) => {
    if (part.startsWith("~") && part.endsWith("~")) {
      return { type: "highlight", content: part.slice(1, -1) };
    }
    return { type: "text", content: part };
  });
}

const bioParts = parseBio(bio);
---

<section class="flex w-full ">
  <div class="flex w-full flex-col">
    <div class="flex w-full items-start justify-between px-4 border-border border-b border-dashed py-3 gap-4">
      <div class="flex flex-col gap-1 min-w-0">
        <h1 class="font-medium text-xl tracking-tight truncate">
          {name}
        </h1>
        <p class="text-xs text-muted-foreground flex flex-wrap gap-x-1.5">
          <span class="truncate">{role}</span>
          <span class="flex items-center gap-0.5 shrink-0">
            <MapPin size={10} />
            <span class="underline">{location}</span>
          </span>
        </p>
      </div>

      <nav class="flex items-center gap-2 sm:gap-3 h-full justify-center text-xs text-muted-foreground shrink-0">
        {socials?.github && (
          <a href={socials.github} class="hover:text-foreground underline-offset-4 hover:underline" target="_blank" rel="noreferrer">
            GitHub
          </a>
        )}
        {socials?.x && (
          <a href={socials.x} class="hover:text-foreground underline-offset-4 hover:underline" target="_blank" rel="noreferrer">
            X
          </a>
        )}
        {socials?.linkedin && (
          <a href={socials.linkedin} class="hover:text-foreground underline-offset-4 hover:underline" target="_blank" rel="noreferrer">
            LinkedIn
          </a>
        )}
        {socials?.email && (
          <a href={socials.email} class="hover:text-foreground underline-offset-4 hover:underline">
            Email
          </a>
        )}
      </nav>
    </div>

    <div class="px-4 py-3 text-sm text-muted-foreground leading-relaxed">
      {bioParts.map((part) => (
        part.type === "highlight" 
          ? <span class="text-foreground underline underline-offset-4 hover:decoration-solid transition-colors">{part.content}</span>
          : part.content
      ))}
    </div>
  </div>
</section>
