---
import { portfolioConfig } from "@/config/portfolio";

const { experience } = portfolioConfig;
---

{experience?.length && (
  <section class="px-4 py-4">
    <h2 class="text-sm font-medium tracking-tight mb-3">Experience</h2>
    <div class="flex flex-col gap-3 text-xs">
      {experience.map((item) => (
        <article class="group relative border-l-2 border-dashed border-border/50 pl-5 py-1.5 hover:border-solid hover:border-primary/50 transition-all duration-300">
          <div class="absolute -left-[6px] top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-background border-2 border-border/60 group-hover:border-primary group-hover:bg-primary transition-all duration-300" />
          <header class="flex flex-col gap-0.5">
            <h3 class="text-xs font-medium">
              {item.role}
              {item.company && (
                <span class="text-foreground">
                  {" at "}
                  {item.company}
                </span>
              )}
            </h3>
            {item.period && (
              <p class="text-[11px] text-muted-foreground">
                {item.period}
              </p>
            )}
          </header>
          {item.summary && (
            <p class="mt-1.5 text-[11px] text-muted-foreground leading-relaxed">
              {item.summary}
            </p>
          )}
        </article>
      ))}
    </div>
  </section>
)}
