---
import { portfolioConfig } from "@/config/portfolio";

const { projects } = portfolioConfig;
---

{projects?.length && (
  <section class="px-4 py-4">
    <h2 class="text-sm font-medium tracking-tight mb-3">Projects</h2>
    <div class="flex flex-col gap-3">
      {projects.map((project) => (
        <article class="border-l border-dashed border-border/70 pl-3">
          <header class="flex items-center justify-between gap-2">
            <a
              href={project.link ?? "#"}
              target={project.link ? "_blank" : undefined}
              rel={project.link ? "noreferrer" : undefined}
              class="text-xs font-medium underline underline-offset-4 decoration-dotted hover:decoration-solid"
            >
              {project.title}
            </a>
          </header>
          {project.description && (
            <p class="mt-1 text-[11px] text-muted-foreground">
              {project.description}
            </p>
          )}
          {project.stack?.length && (
            <div class="mt-1 flex flex-wrap items-center gap-1.5">
              {project.stack.map((tech) => (
                <span class=" border border-dashed border-border/60 px-2 py-[2px] text-[10px] text-muted-foreground">
                  {tech}
                </span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </section>
) }

