---
import { portfolioConfig } from "@/config/portfolio";
;
---

<footer class="px-4 py-6 text-[10px] text-muted-foreground/60 border-t border-dashed border-border/30">
  <div class="flex flex-wrap items-center justify-between gap-x-4 gap-y-2">
    <span class="tracking-wide">
      &copy; {new Date().getFullYear()} {portfolioConfig.name}
    </span>
    <span class="flex items-center gap-1.5 tracking-wide">
      Built with
      <a
        href="https://astro.build/"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-0.5 underline underline-offset-2 text-foreground/80 hover:text-foreground"
      >
        Astro
        <svg class="w-3 h-3 text-muted-foreground group-hover:text-primary transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M7 17L17 7" />
                      <path d="M7 7h10v10" />
                    </svg>
      </a>
    </span>
  </div>
</footer>
