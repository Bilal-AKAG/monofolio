---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog — bearnie">
  <main class="min-h-screen flex flex-col w-full border-x border-dashed border-border">
    <section class="px-6 py-12">
      <h1 class="text-2xl font-semibold mb-8">Blog</h1>
      <div class="space-y-8">
        {posts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.slug}`} class="block">
              <h2 class="text-lg font-medium mb-2 group-hover:text-primary transition-colors inline-flex items-center gap-2">
                {post.data.title}
                <svg class="w-3 h-3 text-muted-foreground group-hover:text-primary transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17L17 7" />
                  <path d="M7 7h10v10" />
                </svg>
              </h2>
              <p class="text-xs text-muted-foreground mb-2">
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </p>
              <p class="text-muted-foreground leading-relaxed">
                {post.data.description}
              </p>
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
