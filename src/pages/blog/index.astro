---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog — bearnie">
  <section class="px-6 py-12 flex-1">
    <h1 class="text-2xl font-semibold mb-8">Blog</h1>
    <div class="space-y-10 py-1">
      {posts.map((post) => (
        <article class="group relative pl-4 border-l border-dashed border-border/40 hover:border-primary/50 hover:bg-secondary/10 -mx-4 px-4 transition-all duration-300">
          <a href={`/blog/${post.slug}`} class="block">
            <p class="text-[10px] text-muted-foreground mb-1 font-medium tracking-wider uppercase py-2">
              {post.data.pubDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </p>
            <h2 class="text-base font-medium mb-1.5 group-hover:text-primary transition-colors">
              {post.data.title}
            </h2>
            <p class="text-sm text-muted-foreground leading-relaxed">
              {post.data.description}
            </p>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
